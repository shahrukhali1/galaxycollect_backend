{
  "version": 2,
  "functions": {
    "api/[...all].ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/[...all].ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/[...all].ts"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/[...all].ts"
    }
  ]
}
